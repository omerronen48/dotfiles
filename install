#!/usr/bin/env bash
# Installer for oronen's dev environment.
# Installs Homebrew packages, casks, taps, oh-my-zsh, p10k, and custom zsh plugins.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="$SCRIPT_DIR/files"

log() { printf "\n\033[1;34m==>\033[0m %s\n" "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }

# Symlink a file from the repo into the system, backing up any existing
# non-symlink file. Symlinks let edits in either place stay in sync with the repo.
link_dotfile() {
  local src="$1" dest="$2"
  if [[ ! -f "$src" ]]; then
    log "Skipping $dest (source $src not found)"
    return
  fi
  mkdir -p "$(dirname "$dest")"
  if [[ -L "$dest" ]]; then
    local current
    current=$(readlink "$dest")
    if [[ "$current" == "$src" ]]; then
      return
    fi
    log "Replacing existing symlink $dest"
    rm "$dest"
  elif [[ -e "$dest" ]]; then
    local backup="$dest.backup.$(date +%Y%m%d%H%M%S)"
    log "Backing up existing $dest -> $backup"
    mv "$dest" "$backup"
  fi
  log "Linking $dest -> $src"
  ln -s "$src" "$dest"
}

# --- Homebrew --------------------------------------------------------------
if ! have brew; then
  log "Installing Homebrew"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi
fi

log "Updating Homebrew"
brew update

# --- Formulae --------------------------------------------------------------
FORMULAE=(
  ant
  awscli
  ccm
  docker
  eza
  fzf
  gh
  git
  jq
  neovim
  openjdk@21
  pipx
  reattach-to-user-namespace
  rtk
  tmux
  tox
  ripgrep
)
log "Installing formulae"
brew install "${FORMULAE[@]}"

# fzf key bindings + completion
if [[ -x "$(brew --prefix)/opt/fzf/install" ]]; then
  log "Installing fzf shell integration"
  "$(brew --prefix)/opt/fzf/install" --all --no-bash --no-fish
fi

# --- Casks -----------------------------------------------------------------
CASKS=(
  alacritty
  codex
  font-meslo-lg-nerd-font
  memoryanalyzer
  warp
)
log "Installing casks"
brew install --cask "${CASKS[@]}"

# --- Headroom (context-compression proxy) ----------------------------------
# pipx isolates it in its own venv so the [all] extras don't clobber other
# Python environments. The `claude` alias in zshrc routes through it.
log "Installing headroom-ai"
pipx install "headroom-ai[all]" 2>/dev/null || pipx upgrade headroom-ai || true

# --- Oh My Zsh -------------------------------------------------------------
export ZSH="${ZSH:-$HOME/.oh-my-zsh}"
if [[ ! -d "$ZSH" ]]; then
  log "Installing Oh My Zsh"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

ZSH_CUSTOM="${ZSH_CUSTOM:-$ZSH/custom}"

# --- Powerlevel10k theme ---------------------------------------------------
clone_or_pull() {
  local repo="$1" dest="$2"
  if [[ -d "$dest" ]]; then
    log "Updating $(basename "$dest")"
    git -C "$dest" pull --ff-only || true
  else
    log "Cloning $(basename "$dest")"
    git clone --depth=1 "$repo" "$dest"
  fi
}

clone_or_pull https://github.com/romkatv/powerlevel10k.git \
  "$ZSH_CUSTOM/themes/powerlevel10k"

# --- Custom zsh plugins ----------------------------------------------------
declare -a PLUGINS=(
  "zsh-autosuggestions|https://github.com/zsh-users/zsh-autosuggestions"
  "zsh-syntax-highlighting|https://github.com/zsh-users/zsh-syntax-highlighting.git"
  "fast-syntax-highlighting|https://github.com/zdharma-continuum/fast-syntax-highlighting.git"
  "zsh-autocomplete|https://github.com/marlonrichert/zsh-autocomplete.git"
  "zsh-history-substring-search|https://github.com/zsh-users/zsh-history-substring-search"
  "zsh-autopair|https://github.com/hlissner/zsh-autopair"
  "zsh-you-should-use|https://github.com/MichaelAquilina/zsh-you-should-use.git"
)
# zsh-interactive-cd ships with oh-my-zsh as a built-in plugin.

for entry in "${PLUGINS[@]}"; do
  name="${entry%%|*}"
  url="${entry##*|}"
  clone_or_pull "$url" "$ZSH_CUSTOM/plugins/$name"
done

# --- Dotfiles --------------------------------------------------------------
# Symlinked from this repo so edits flow both ways.
link_dotfile "$DOTFILES_DIR/zshrc"          "$HOME/.zshrc"
link_dotfile "$DOTFILES_DIR/p10k.zsh"       "$HOME/.p10k.zsh"
link_dotfile "$DOTFILES_DIR/claude-panes.sh" "$HOME/.config/tmux/claude-panes.sh"
link_dotfile "$DOTFILES_DIR/tmux.conf"      "$HOME/.tmux.conf"
link_dotfile "$DOTFILES_DIR/init.lua"       "$HOME/.config/nvim/init.lua"
link_dotfile "$DOTFILES_DIR/alacritty.toml" "$HOME/.config/alacritty/alacritty.toml"
link_dotfile "$DOTFILES_DIR/claude.md"      "$HOME/.claude/CLAUDE.md"

# --- Claude skills (oroskills) -----------------------------------------------
# Cloned to a stable dir so the symlinks its installer creates keep resolving.
clone_or_pull https://github.com/omerronen48/oroskills.git "$HOME/.oroskills"
if [[ -x "$HOME/.oroskills/install.sh" ]]; then
  log "Installing oroskills (Claude skills)"
  "$HOME/.oroskills/install.sh" --global || true
fi

# --- TPM (tmux plugin manager) --------------------------------------------
clone_or_pull https://github.com/tmux-plugins/tpm.git "$HOME/.tmux/plugins/tpm"

# Install/update plugins declared in tmux.conf without needing an active tmux session.
if [[ -x "$HOME/.tmux/plugins/tpm/bin/install_plugins" ]]; then
  log "Installing tmux plugins via TPM"
  "$HOME/.tmux/plugins/tpm/bin/install_plugins" || true
fi
if [[ -x "$HOME/.tmux/plugins/tpm/bin/update_plugins" ]]; then
  "$HOME/.tmux/plugins/tpm/bin/update_plugins" all || true
fi

# --- NVM -------------------------------------------------------------------
if [[ ! -d "$HOME/.nvm" ]]; then
  log "Installing nvm"
  PROFILE=/dev/null bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh)"
fi

log "Done. Restart your shell or run: source ~/.zshrc"
log "Your prompt is preconfigured via ~/.p10k.zsh. Run 'p10k configure' only if you want to change it."
